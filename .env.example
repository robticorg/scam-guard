# Discord bot token for ScamGuard (required)
TOKEN=your_scamguard_bot_token_here

# Channel ID where ScamGuard posts moderation alerts (optional)
# Leave empty to disable alerts
LOG_CHANNEL_ID=your_log_channel_id_here

# ── Testing only 
# Bot token for the secondary "attacker" bot used in tests
SPAMMER_TOKEN=your_spammer_bot_token_here

# Guild ID where both bots are members and ScamGuard is active
TEST_GUILD_ID=your_guild_id_here

# Comma-separated list of at least 4 text channel IDs for the test suite
TEST_CHANNEL_IDS=channel_id_1,channel_id_2,channel_id_3,channel_id_4

# Set to 1 to allow ScamGuard to process messages from bot accounts (needed for tests)
# Never set this in production
ALLOW_BOT_MESSAGES=
